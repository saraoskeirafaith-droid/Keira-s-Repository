class ShoppingCart:
    def __init__(self):
        self.cart = []

    def show_cart(self):
        if not self.cart:
            print("Cart is empty.")
        else:
            print("Items in cart:")
            for item in self.cart:
                print("-", item)

    def add_item(self):
        item = input("Enter item to add: ")
        self.cart.append(item)
        print("Item added to cart.")

    def remove_item(self):
        item = input("Enter item to remove: ")
        if item in self.cart:
            self.cart.remove(item)
            print("Item removed from cart.")
        else:
            print("Item not found in cart.")

    def checkout(self):
        if not self.cart:
            print("Cart is empty. Nothing to checkout.")
        else:
            print("Checking out the following items:")
            for item in self.cart:
                print("-", item)
            print("Thank you for shopping!")
            self.cart.clear()


cart = ShoppingCart()

while True:
    print("\nShopping Cart System")
    print("1. View Cart")
    print("2. Add Item")
    print("3. Remove Item")
    print("4. Checkout")
    print("5. Exit")

    choice = input("Choose option (1-5): ")

    if choice == "1":
        cart.show_cart()

    elif choice == "2":
        cart.add_item()

    elif choice == "3":
        cart.remove_item()

    elif choice == "4":
        cart.checkout()

    elif choice == "5":
        print("Exit program.")
        break

    else:
        print("Invalid choice.")

    input("\nPress Enter to continue...")
